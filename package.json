{
  "name": "scrollvessel.com",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm build && vite preview",
    "generate:fonts": "tsx scripts/generate-font-assets.ts",
    "validate:content": "tsx scripts/validate-content.ts",
    "build": "pnpm generate:fonts && pnpm validate:content && vite build && tsx scripts/generate-static-pages.ts",
    "preview": "vite preview",
    "prepare": "lefthook install --force",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/crimson-pro": "^5.2.8",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@vitejs/plugin-vue": "latest",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "vite": "latest",
    "vue": "latest"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tailwindcss/postcss": "latest",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "latest",
    "autoprefixer": "latest",
    "lefthook": "^2.1.8",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
